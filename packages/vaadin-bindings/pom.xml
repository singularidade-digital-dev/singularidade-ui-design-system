<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>digital.singularidade</groupId>
        <artifactId>singularidade-ui-design-system-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>vaadin-bindings</artifactId>
    <packaging>jar</packaging>
    <name>Singularidade Vaadin Bindings</name>
    <description>Vaadin Flow theme bridge mapping design tokens to --vaadin-* component vars</description>

    <properties>
        <vaadin.version>25.1.2</vaadin.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>com.vaadin</groupId>
            <artifactId>flow-server</artifactId>
            <version>${vaadin.version}</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>digital.singularidade</groupId>
            <artifactId>tokens</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>digital.singularidade</groupId>
            <artifactId>brand-assets</artifactId>
            <version>${project.version}</version>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>themes/singularidade</directory>
                <targetPath>META-INF/resources/themes/singularidade</targetPath>
            </resource>
        </resources>

        <plugins>
            <plugin>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
