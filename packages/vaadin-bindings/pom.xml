<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>digital.singularidade</groupId>
        <artifactId>singularidade-ui-design-system-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>vaadin-bindings</artifactId>
    <packaging>jar</packaging>
    <name>Singularidade Vaadin Bindings</name>
    <description>Vaadin Flow theme bridge — provides singularidade-base parent theme mapping tokens to --lumo-*</description>

    <properties>
        <vaadin.version>24.9.10</vaadin.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>com.vaadin</groupId>
            <artifactId>flow-server</artifactId>
            <version>${vaadin.version}</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>digital.singularidade</groupId>
            <artifactId>tokens</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>digital.singularidade</groupId>
            <artifactId>brand-assets</artifactId>
            <version>${project.version}</version>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>themes/singularidade-base</directory>
                <targetPath>META-INF/resources/themes/singularidade-base</targetPath>
            </resource>
            <!--
              Pull brand×theme CSS and font assets from sibling packages at build time,
              so the source-of-truth lives in @singularidade/tokens (Style Dictionary
              output in build/css) and @singularidade/brand-assets (src/fonts), and
              vaadin-bindings serves them under /themes/singularidade-base/{tokens,fonts}/
              — the only path Spring Security / Vaadin Flow allow by default.

              Alternative considered: keep tokens/brand-assets at their natural
              classpath locations (/tokens/css/*, /brand-assets/fonts/*) and have
              consumers add Spring Security `requestMatchers("/tokens/**", "/brand-assets/**").permitAll()`.
              Rejected because it pushes asset-path knowledge into every consumer's
              security config — breaking encapsulation. With this Maven resource
              copy, the design-system ships a single self-contained `/themes/<name>`
              tree that any Vaadin app picks up without security-config changes.
            -->
            <resource>
                <directory>../tokens/build/css</directory>
                <targetPath>META-INF/resources/themes/singularidade-base/tokens</targetPath>
                <includes>
                    <include>integras.*.css</include>
                    <include>singularidade.*.css</include>
                </includes>
            </resource>
            <resource>
                <directory>../brand-assets/src/fonts</directory>
                <targetPath>META-INF/resources/themes/singularidade-base/fonts</targetPath>
            </resource>
        </resources>

        <plugins>
            <plugin>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
