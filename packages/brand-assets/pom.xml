<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>digital.singularidade</groupId>
        <artifactId>singularidade-ui-design-system-parent</artifactId>
        <version>0.1.0-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>brand-assets</artifactId>
    <packaging>jar</packaging>
    <name>Singularidade Brand Assets</name>
    <description>Brand logos, icons, fonts, illustrations packaged as classpath resources</description>

    <build>
        <resources>
            <resource>
                <directory>src/logos</directory>
                <targetPath>META-INF/resources/brand-assets/logos</targetPath>
            </resource>
            <resource>
                <directory>src/icons</directory>
                <targetPath>META-INF/resources/brand-assets/icons</targetPath>
            </resource>
            <resource>
                <directory>src/fonts</directory>
                <targetPath>META-INF/resources/brand-assets/fonts</targetPath>
            </resource>
            <resource>
                <directory>build</directory>
                <targetPath>META-INF/resources/brand-assets</targetPath>
            </resource>
        </resources>

        <plugins>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>build-brand-assets</id>
                        <phase>generate-resources</phase>
                        <goals><goal>exec</goal></goals>
                        <configuration>
                            <executable>pnpm</executable>
                            <arguments>
                                <argument>--filter</argument>
                                <argument>@singularidade/brand-assets</argument>
                                <argument>build</argument>
                            </arguments>
                            <workingDirectory>${project.basedir}/../..</workingDirectory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
